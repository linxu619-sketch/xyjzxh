# ============================================================
# 信阳建装平台 · 环境变量模板
# 复制为 .env.local 并填写;.env.local 已 gitignore。
# 多数 AI / e签宝 / 监管 配置也可在「协会工作台 → 系统设置」中填写,
# 存入 .runtime-settings.json(同样 gitignore),无需改环境变量。
# ============================================================

# —— 必填(生产)——
# 会话签名密钥。生产环境必须设置(未设置将启动报错),用随机长字符串。
# 生成： node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# —— HTTP 部署开关(可选)——
# 若经 HTTP(无 HTTPS)对外,如公网 IP 直连演示,设为 1 关闭 session cookie 的 Secure 标志,
# 否则浏览器不会保存登录态 cookie、登录后仍是未登录。上 HTTPS 后请删除此项。
# COOKIE_INSECURE=1

# —— 每日知识库自动抓取 cron(可选;配了才启用定时抓取接口)——
# 保护 /api/cron/knowledge-fetch 接口的密钥,供 OS 定时器调用;未配置则接口拒绝执行(503)。
# 生成： node -e "console.log(require('crypto').randomBytes(24).toString('hex'))"
# 部署脚本与说明见 scripts/cron/README.md
# CRON_SECRET=

# —— AI(可选;留空走演示态或在系统设置填写)——
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-v4-flash
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# AI_PROVIDER=auto                 # auto | deepseek
# ANTHROPIC_API_KEY=               # 备用 AI 提供方
# ANTHROPIC_MODEL=

# —— 数据库(默认本地 SQLite data/app.db,零配置)——
# 上线多人高并发时再迁移到独立 Postgres,届时在此追加连接串:
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# —— 电子签 e签宝(可选;留空使用协会原生签)——
# EQIANBAO_APP_ID=
# EQIANBAO_APP_KEY=
# EQIANBAO_BASE_URL=https://smlopenapi.esign.cn
# EQIANBAO_CALLBACK_URL=

# —— 其它待接(在系统设置中配置)——
# 短信网关(阿里云/腾讯云)、对象存储(OSS/COS)、省厅监管平台等
# 见「协会工作台 → 系统设置」与平台文档「上线清单」。
