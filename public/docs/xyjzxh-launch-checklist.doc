 th,td{border:1px solid #b8c2d8;padding:6px 8px;text-align:left;vertical-align:top;}
 th{background:#eaf0ff;color:#0b2a6b;}
 .ok{color:#0a8a5f;font-weight:bold;} .warn{color:#c0392b;font-weight:bold;} .todo{color:#a37200;font-weight:bold;}
 .cover{text-align:center;margin:40px 0 28px;}
 .cover .t{font-size:28pt;font-weight:bold;color:#0b2a6b;}
