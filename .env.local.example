# ============================================================
# 信阳市建筑装修协会 · 环境变量示例
# 用法：复制为 .env.local（已被 .gitignore），然后填入真实值
# ============================================================
# 提示：所有 key 也可以在 系统设置 UI 里填，UI 优先级更高。

# ----- AI 提供方（任选其一即可启用真聊天）-----
# 优先级：DEEPSEEK_API_KEY > ANTHROPIC_API_KEY > 演示模式
# 强制指定提供方：AI_PROVIDER=deepseek | anthropic | demo
DEEPSEEK_API_KEY=sk-填入你的-deepseek-key
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Anthropic Claude（兜底）
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ----- 会话密钥（生产必须改）-----
# 生成方法： node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# SESSION_SECRET=...

# ----- Supabase（接入后填）-----
# 步骤：
#   1. https://supabase.com/dashboard/projects 新建项目（免费层够用）
#   2. Settings → API 拿到 URL 和 keys
#   3. SQL Editor 跑 db/schema.sql 再跑 db/seed.sql
#   4. 把下面三行填好，重启 dev（或保存到 系统设置 UI）
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJxxx...
SUPABASE_SERVICE_ROLE_KEY=eyJxxx...
